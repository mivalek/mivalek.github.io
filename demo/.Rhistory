ind <- ind[grep("img src", x[ind], invert = T)]
x[ind] <-  gsub("^(\\s*?<link rel=\"stylesheet\" href=\").*?(slides_files.*)$", "\\1/demo/\\2", x[ind])
x[ind] <-  gsub("^(\\s*?<link href=\").*?(slides_files.*)$", "\\1/demo/\\2", x[ind])
x[ind] <-  gsub("^(\\s*?<script src=\").*?(slides_files.*)$", "\\1/demo/\\2", x[ind])
x[ind] <-  gsub("^(\\s*?\\{ src: ').*?(slides_files.*)$", "\\1/demo/\\2", x[ind])
