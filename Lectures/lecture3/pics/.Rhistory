plot(p, add = T, col = "#eee8d5")
abline(v = sample_mean[j], col = "#ffa733")
plot(NULL, main = "Sampling distribution of the mean", xlim = c(.3, .7),
ylim = c(0, max(sampling_p$counts)), xlab = "", ylab = "", col.ticks = "#93a1a1")
polygon(x2, scale(y2, F, scale = scale_y2), col = "#93a1a1", border = NA)
abline(v = sample_mean[j], col = "#ffa733")
hist(sample_mean[1:j], add = T, col = "#ffa733", breaks = sampling_p$breaks)
}
