system('"C:\\Program Files\\ImageMagick-7.0.7-Q16\\magick.exe" -delay 2 -loop 1 *.png clt_slide.gif')
file.remove("*.png")
list.files(".png")
setwd("~/teaching/clt")
set.seed(1)
rbimod <- function(x, alpha, beta) c(rbeta(x/2, alpha, beta), rbeta(x/2, beta, alpha))
x <- seq(0, 1, .01)
y <- dbeta(x, 2, 10) + dbeta(x, 10, 2)
s <- replicate(1000, rbimod(20, 2, 10)) # N = 20
max_y <- max(apply(s, 2, function(x) max(hist(x, plot = F)$counts)))
mu <- mean(s)
x_bar <- apply(s, 2, mean)
se <- sd(x_bar)
x2 <- seq(range(x_bar)[1] - .05, range(x_bar)[2] + .05, length.out = 100)
y2 <- dnorm(x2, mu, se)
sampling_p <- hist(x_bar, breaks = 100, plot = F)
png("sample%04d.png", 500, 500)
# par(mfrow = 2:1)
## replace colours: grey = #93a1a1, darkgreen = #eee8d5, purple = #ffa733
## remove , col.ticks = "#93a1a1" from all plots
par(mfrow = 2:1, bg = "#002b36", col = "#93a1a1", col.axis = "#93a1a1", col.lab = "#93a1a1", col.main = "#93a1a1", col.sub = "#93a1a1")
sample_mean <- NA
### to get density plots and histograms on the same y scale
# trial and error
scale_y <- max(y)/5
scale_y2 <- max(y2)/40
for (i in 1:40) {
plot(x, y, type = "n", ylim = c(0, max_y), xlab = "", ylab = "", main = "Sample (N = 20)", col.ticks = "#93a1a1")
polygon(x, scale(y, F, scale = scale_y), col = "#93a1a1", border = NA)
plot(NULL, main = "Sampling distribution of the mean", xlim = c(.3, .7),
ylim = c(0, max(sampling_p$counts)), xlab = "", ylab = "", col.ticks = "#93a1a1")
polygon(x2, scale(y2, F, scale = scale_y2), col = "#93a1a1", border = NA)
}
